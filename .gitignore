dist/
build/
out/
*.tsbuildinfo
.tscache/

# Test / coverage
coverage/
.nyc_output/
*.lcov

# ─── Rust (server/) ───────────────────────────────────────────────────────────
target/
**/*.rs.bk
*.pdb
