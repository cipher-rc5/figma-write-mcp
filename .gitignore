.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.pfx
*.crt
secrets/
.secrets/

# ─── Node / Bun (plugin/) ─────────────────────────────────────────────────────
node_modules/
.pnp.*
.yarn/
.npm/
.bun/
bun-debug.log
bun-error.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
