!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.iml
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Logs / temp ──────────────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/
*.pid
*.seed
*.pid.lock

# ─── Claude Code local overrides ──────────────────────────────────────────────
