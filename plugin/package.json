{
  "name": "figma-write-mcp-plugin",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun build ./code.ts --outdir=./dist --target=browser --format=esm",
    "watch": "bun build ./code.ts --outdir=./dist --target=browser --format=esm --watch",
    "typecheck": "tsgo -p tsconfig.json --noEmit && tsgo -p tsconfig.test.json --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@figma/plugin-typings": "1.126.0",
    "@typescript/native-preview": "7.0.0-dev.20260519.1",
    "bun-types": "1.3.14"
  }
}
